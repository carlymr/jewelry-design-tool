# Supabase — from your project's Settings → API Keys
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
# Legacy fallback (used only if the publishable key var is unset):
# NEXT_PUBLIC_SUPABASE_ANON_KEY=...

# Anthropic — used server-side by the receipt-processing API route
ANTHROPIC_API_KEY=sk-ant-...

# Shared secret guarding the API routes against drive-by abuse (any random
# string, e.g. `openssl rand -hex 24`). Not real auth — it ships in the
# client bundle. Optional: if unset, the routes accept all requests.
NEXT_PUBLIC_API_TOKEN=
